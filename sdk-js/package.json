{
  "name": "littlehorse-client",
  "version": "0.0.0-development",
  "license": "Apache-2.0",
  "description": "Littlehorse gPRC Client",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/littlehorse-enterprises/littlehorse.git",
    "directory": "sdk-js"
  },
  "engines": {
    "node": ">=18.14.0"
  },
  "types": "dist/index.d.ts",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./proto": {
      "import": "./dist/proto/index.js",
      "types": "./dist/proto/index.d.ts",
      "default": "./dist/proto/index.js"
    },
    "./worker": {
      "import": "./dist/worker/index.js",
      "types": "./dist/worker/index.d.ts",
      "default": "./dist/worker/index.js"
    }
  },
  "files": [
    "/dist"
  ],
  "packageManager": "pnpm@10.19.0",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "lint": "prettier --check .",
    "lint:fix": "prettier --write ."
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@tsconfig/node20": "^20.1.6",
    "@types/jest": "^29.5.12",
    "@types/node": "^24.1.0",
    "eslint": "^9.31.0",
    "jest": "^29.7.0",
    "lint-staged": "^16.1.2",
    "prettier": "^3.6.2",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "typescript": "5.3.3"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.12.5",
    "@protobuf-ts/grpc-transport": "^2.11.1",
    "@protobuf-ts/runtime": "^2.11.1",
    "@protobuf-ts/runtime-rpc": "^2.11.1",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  }
}
